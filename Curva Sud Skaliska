                            <div class="flex gap-2 mt-1">
                                <span class="text-[8px] font-bold bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded">Pembina: ${totalPembina}</span>
                                <span class="text-[8px] font-bold bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded">Alumni: ${totalAlumni}</span>
                            </div>
                        </div>
                    </div>

                    <!-- BARIS 3: SURAT & AGENDA -->
                    <div class="grid grid-cols-2 gap-3">
                        <div onclick="bukaHalamanArsip('administrasi')" class="cursor-pointer bg-white p-4 rounded-2xl border border-slate-200 shadow-sm">
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tight">Jumlah Surat</p>
                            <p class="text-2xl font-black text-amber-600">${suratMasuk + suratKeluar}</p>
                            <div class="flex gap-2 mt-1">
                                <span class="text-[8px] font-bold text-emerald-600">Masuk: ${suratMasuk}</span>
                                <span class="text-[8px] font-bold text-rose-600">Keluar: ${suratKeluar}</span>
                            </div>
                        </div>
                        <div onclick="bukaHalamanArsip('agenda')" class="cursor-pointer bg-white p-4 rounded-2xl border border-slate-200 shadow-sm">
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tight">Jumlah Agenda</p>
                            <p class="text-2xl font-black text-teal-600">${totalAgenda}</p>
                            <p class="text-[8px] text-slate-400 font-medium">Kegiatan Terjadwal</p>
                        </div>
                    </div>

                    <!-- BARIS 4: PROKER & EVALUASI -->
                    <div class="grid grid-cols-2 gap-3">
                        <div onclick="bukaHalamanArsip('program_kerja')" class="cursor-pointer bg-white p-4 rounded-2xl border border-slate-200 shadow-sm">
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tight">Program Kerja</p>
                            <p class="text-2xl font-black text-sky-600">${prokerSelesai + prokerBelum}</p>
                            <div class="flex flex-col mt-1">
                                <span class="text-[8px] font-bold text-emerald-600">Selesai: ${prokerSelesai}</span>
                                <span class="text-[8px] font-bold text-rose-500">Belum Selesai: ${prokerBelum}</span>
                            </div>
                        </div>
                        <!-- EVALUASI DENGAN BLOCK MERAH -->
                        <div onclick="bukaHalamanArsip('evaluasi')" class="cursor-pointer bg-rose-600 p-4 rounded-2xl border border-rose-700 shadow-lg">
                            <p class="text-[9px] font-bold text-rose-100 uppercase tracking-tight">Jumlah Evaluasi</p>
                            <p class="text-2xl font-black text-white">${totalEvaluasi}</p>
                            <p class="text-[8px] text-rose-200 font-medium italic">Laporan Kendala Sistem</p>
                        </div>
                    </div>

                    <!-- KEUANGAN -->
                    <div onclick="bukaHalamanArsip('keuangan')" class="cursor-pointer bg-slate-900 p-5 rounded-3xl shadow-xl text-white relative overflow-hidden">
                        <div class="absolute -right-4 -top-4 opacity-10 text-6xl">
                            <i class="fa-solid fa-wallet"></i>
                        </div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase mb-1 tracking-widest">Saldo Kas Organisasi</p>
                        <p class="text-3xl font-black text-emerald-400 mb-4">Rp ${saldoAkhir.toLocaleString('id-ID')}</p>
                        <div class="grid grid-cols-2 gap-4 pt-4 border-t border-white/10">
                            <div>
                                <p class="text-[8px] text-slate-500 uppercase font-bold mb-1">Total Pemasukan</p>
                                <p class="text-xs font-bold text-emerald-300">Rp ${totalPemasukan.toLocaleString('id-ID')}</p>
                            </div>
                            <div>
                                <p class="text-[8px] text-slate-500 uppercase font-bold mb-1">Total Pengeluaran</p>
                                <p class="text-xs font-bold text-rose-400">Rp ${keluar.toLocaleString('id-ID')}</p>
                            </div>
                        </div>
                    </div>
                `;
            } else {
                // DASHBOARD ANGGOTA
                const agt = loggedMemberData;
                const now = new Date();
                const currentMonthIdx = now.getMonth();
                const currentYear = now.getFullYear();
                const selectedBln = document.getElementById('dash_bln_user')?.value || listBulan[currentMonthIdx];
                const selectedThn = document.getElementById('dash_thn_user')?.value || currentYear;
                const myKas = storageOrganisasi.kas_tim.filter(k => {
                    const d = new Date(k.tanggal);
                    return k.nama === agt.nama_lengkap && listBulan[d.getMonth()] === selectedBln && d.getFullYear() == selectedThn;
                });
                const myAbs = storageOrganisasi.absensi.filter(a => a.nama === agt.nama_lengkap && a.bulan === selectedBln && a.tahun == selectedThn);
                let h=0, i=0, s=0, a=0; 
                myAbs.forEach(abs => { 
                    if(abs.kehadiran === "Hadir") h++; else if(abs.kehadiran === "Izin") i++; else if(abs.kehadiran === "Sakit") s++; else if(abs.kehadiran === "Alpa") a++; 
                });
                let totalBayar = 0; myKas.forEach(k => totalBayar += parseFloat(k.nominal || 0));

                wadah.innerHTML = `
                    <div class="bg-white p-5 rounded-3xl border shadow-sm flex flex-col items-center">
                        <img src="${agt.foto || 'https://via.placeholder.com/150'}" class="w-20 h-20 rounded-full object-cover border-4 border-emerald-100 mb-3">
                        <h2 class="text-sm font-bold text-slate-800 uppercase">${agt.nama_lengkap}</h2>
                        <p class="text-[9px] text-slate-500 font-bold uppercase mb-4">Kelas: ${agt.kelas} | Angkatan: ${agt.angkatan || '-'}</p>
                        <div class="w-full grid grid-cols-2 gap-2 mb-4">
                            <select id="dash_bln_user" onchange="segarkanDashboardStatistik()" class="text-[10px] bg-slate-50 border border-slate-200 rounded-lg p-2 font-bold">${listBulan.map(b => `<option value="${b}" ${b===selectedBln ? 'selected' : ''}>${b}</option>`).join('')}</select>
                            <select id="dash_thn_user" onchange="segarkanDashboardStatistik()" class="text-[10px] bg-slate-50 border border-slate-200 rounded-lg p-2 font-bold">${generateOpsiTahun(2023, 3000).replace(`value="${selectedThn}"`, `value="${selectedThn}" selected`)}</select>
                        </div>
                        <div class="w-full grid grid-cols-2 gap-2">
                            <div class="bg-emerald-50 p-3 rounded-xl text-center"><p class="text-[8px] font-bold text-emerald-600 uppercase">Kas (${selectedBln})</p><p class="text-xs font-black text-slate-800">Rp ${totalBayar.toLocaleString('id-ID')}</p></div>
                            <div class="bg-blue-50 p-3 rounded-xl text-center"><p class="text-[8px] font-bold text-blue-600 uppercase">Hadir (${selectedBln})</p><p class="text-xs font-black text-slate-800">${h} Kali</p></div>
                        </div>
                    </div>
                    <div class="bg-white p-4 rounded-2xl border border-slate-100">
                        <h3 class="text-[9px] font-bold text-slate-400 uppercase mb-3">Rincian Kehadiran - ${selectedBln} ${selectedThn}</h3>
                        <div class="grid grid-cols-4 gap-1 text-center">
                            <div class="p-2 rounded bg-emerald-100"><p class="text-[7px] font-bold">H</p><p class="text-xs font-bold">${h}</p></div>
                            <div class="p-2 rounded bg-blue-100"><p class="text-[7px] font-bold">I</p><p class="text-xs font-bold">${i}</p></div>
                            <div class="p-2 rounded bg-amber-100"><p class="text-[7px] font-bold">S</p><p class="text-xs font-bold">${s}</p></div>
                            <div class="p-2 rounded bg-rose-100"><p class="text-[7px] font-bold">A</p><p class="text-xs font-bold">${a}</p></div>
                        </div>
                    </div>
                `;
            }
        }

        function eksporDataCSV() {
            let data = storageOrganisasi[kategoriArsipAktif];
            if(!data || data.length === 0) return;
            let csv = Object.keys(data[0]).filter(k => k !== 'foto' && k !== 'file').join(",") + "\n" + data.map(i => Object.entries(i).filter(([k]) => k !== 'foto' && k !== 'file').map(([_, v]) => `"${v}"`).join(",")).join("\n");
            let link = document.createElement("a"); link.href = encodeURI("data:text/csv;charset=utf-8," + csv); link.download = `Data_${kategoriArsipAktif}.csv`; link.click();
        }

        function eksporDataPDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF('l', 'mm', 'a4');
            doc.text(kategoriArsipAktif.toUpperCase(), 14, 15);
            doc.autoTable({ html: 'table', startY: 25, theme: 'striped', headStyles: { fillColor: [16, 185, 129] } });
            doc.save(`Laporan_${kategoriArsipAktif}.pdf`);
        }

        function jalankanFiturCari() {
            currentPage = 1;
            renderListArsip();
        }

        function aksiHapusData(kat, id) { if(confirm("Hapus permanen?")) database.ref('administrasi_digital/' + kat + '/' + id).remove(); }

        function renderAkumulasiKas() {
            const wadahAkumulasi = document.getElementById('container-akumulasi-data');
            const dataKas = storageOrganisasi.kas_tim;
            let dataAnggota = storageOrganisasi.anggota;
            if(dataAnggota.length === 0) return;
            document.getElementById('akumulasi-khusus-container').classList.remove('hidden');
            
            const start = (currentPage - 1) * rowsPerPage;
            const paginatedAnggota = dataAnggota.slice(start, start + rowsPerPage);
            
            const listPeriode = []; for (let m = 0; m < 12; m++) listPeriode.push({ bln: m, thn: 2026 });
            const pMap = {}; dataKas.forEach(k => { const d = new Date(k.tanggal); pMap[`${k.nama}_${d.getFullYear()}_${d.getMonth()}`] = true; });
            
            let html = `<table><thead><tr><th>No</th><th>Nama Anggota</th>`;
            listPeriode.forEach(p => html += `<th>${new Date(p.thn, p.bln).toLocaleString('id-ID', { month: 'short' })}</th>`);
            html += `<th>Total</th></tr></thead><tbody>`;
            
            paginatedAnggota.forEach((agt, idx) => {
                let lunas = 0; html += `<tr><td>${start + idx + 1}</td><td class="font-bold">${agt.nama_lengkap}</td>`;
                listPeriode.forEach(p => { 
                    const ok = pMap[`${agt.nama_lengkap}_${p.thn}_${p.bln}`]; 
                    html += `<td class="text-center"><span class="${ok ? 'text-emerald-500' : 'text-rose-500'}">●</span></td>`; 
                    if(ok) lunas++; 
                });
                html += `<td class="text-emerald-600 font-bold">${lunas}</td></tr>`;
            });
            html += `</tbody></table>`; wadahAkumulasi.innerHTML = html;
        }
    </script>
</body>
</html>
