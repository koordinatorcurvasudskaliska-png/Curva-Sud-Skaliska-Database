        async function aksiKonfirmasiPendaftaran(id) {
            if(!confirm("Pindahkan pendaftar ini ke Anggota Massa Tetap?")) return;
            const data = storageOrganisasi.pendaftaran.find(x => x.id == id);
            if(!data) return;
            const dataBaru = {
                id: data.id,
                nama_lengkap: data.nama,
                gender: data.gender,
                tempat_lahir: data.tempat_lahir || "",
                tanggal_lahir: data.tanggal_lahir || "",
                kelas: data.kelas || "",
                whatsapp: data.whatsapp || "",
                foto: data.foto || "",
                angkatan: data.angkatan || ""
            };
            try {
                await database.ref('administrasi_digital/anggota/' + data.id).set(dataBaru);
                await database.ref('administrasi_digital/pendaftaran/' + id).remove();
                alert("Berhasil dikonfirmasi!");
            } catch(e) { alert(e.message); }
        }

        function renderListArsip() {
            const wadah = document.getElementById('container-list-arsip');
            let data = storageOrganisasi[kategoriArsipAktif];
            document.getElementById('akumulasi-khusus-container').classList.add('hidden');
            
            if(kategoriArsipAktif === 'raport') { renderRaportSummary(); return; }
            if(!data || data.length === 0) { 
                wadah.innerHTML = `<div class="p-8 text-center text-slate-400 text-[10px] font-bold">Tabel Kosong</div>`; 
                document.getElementById('pagination-controls').classList.add('hidden');
                return; 
            }

            const kueri = document.getElementById('inputCariArsip').value.toLowerCase();
            if(kueri) {
                data = data.filter(item => JSON.stringify(item).toLowerCase().includes(kueri));
            }

            const totalPages = Math.ceil(data.length / rowsPerPage);
            if (currentPage > totalPages) currentPage = Math.max(1, totalPages);
            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;
            const paginatedData = data.slice(start, end);

            document.getElementById('pagination-controls').classList.remove('hidden');
            document.getElementById('btn-prev').disabled = currentPage === 1;
            document.getElementById('btn-next').disabled = currentPage === totalPages;
            document.getElementById('info-halaman').innerText = `Hal ${currentPage} dari ${totalPages}`;

            let html = `<table><thead><tr><th>No</th>`;
            const sample = data[0]; const keys = Object.keys(sample).filter(k => k !== 'id' && k !== 'foto' && k !== 'file');
            if(sample.foto !== undefined) html += `<th>Foto</th>`;
            if(sample.file !== undefined) html += `<th>File</th>`;
            keys.forEach(k => html += `<th>${k.replace(/_/g, ' ')}</th>`);
            html += `<th>Aksi</th></tr></thead><tbody>`;
            
            paginatedData.forEach((item, index) => {
                html += `<tr><td>${start + index + 1}</td>`;
                if(item.foto !== undefined) html += `<td><img src="${item.foto || 'https://via.placeholder.com/50'}" class="img-circle" onclick="bukaPopUpFoto('${item.foto}', '${item.nama || item.nama_lengkap}')"></td>`;
                if(item.file !== undefined) html += `<td><button class="text-emerald-600 font-bold" onclick="bukaPopUpFoto('${item.file}', 'Berkas Digital')"><i class="fa-solid fa-file-pdf"></i> Lihat</button></td>`;
                keys.forEach(k => html += `<td>${item[k]}</td>`);
                
                html += `<td class="flex gap-1">`;
                if(kategoriArsipAktif === 'pendaftaran') {
                    html += `<button onclick="aksiKonfirmasiPendaftaran('${item.id}')" class="text-emerald-500 mr-2"><i class="fa-solid fa-circle-check"></i></button>`;
                }
                html += `<button onclick="aksiHapusData('${kategoriArsipAktif}','${item.id}')" class="text-rose-500"><i class="fa-solid fa-trash"></i></button></td></tr>`;
            });
            html += `</tbody></table>`; wadah.innerHTML = html;
            if(kategoriArsipAktif === 'kas_tim') renderAkumulasiKas();
        }

