        function downloadRaportPDF_User(memberId) {
            const agt = storageOrganisasi.anggota.find(x => x.id == memberId);
            if (!agt) return;

            const { jsPDF } = window.jspdf;
            const doc = new jsPDF('p', 'mm', 'a4');
            const pageWidth = doc.internal.pageSize.getWidth();

            // Header
            doc.setFont("helvetica", "bold");
            doc.setFontSize(14);
            doc.text("RAPORT ANGGOTA MASSA TETAP", pageWidth/2, 20, { align: 'center' });
            doc.text("CURVA SUD SKALISKA", pageWidth/2, 27, { align: 'center' });
            
            doc.setLineWidth(0.5);
            doc.line(20, 32, pageWidth - 20, 32);

            // Biodata
            doc.setFontSize(10);
            doc.setFont("helvetica", "normal");
            let y = 42;
            const labelX = 25;
            const valueX = 65;

            const bios = [
                ["Nama Lengkap", agt.nama_lengkap],
                ["Gender", agt.gender],
                ["Kelas", agt.kelas],
                ["Angkatan", agt.angkatan || "-"],
                ["Tempat, Tgl Lahir", `${agt.tempat_lahir || "-"}, ${agt.tanggal_lahir || "-"}`],
                ["WhatsApp", agt.whatsapp]
            ];

            bios.forEach(b => {
                doc.setFont("helvetica", "bold");
                doc.text(b[0], labelX, y);
                doc.text(":", valueX - 5, y);
                doc.setFont("helvetica", "normal");
                doc.text(String(b[1]), valueX, y);
                y += 7;
            });

            // Tabel 1: Rekap Pembayaran
            y += 10;
            doc.setFont("helvetica", "bold");
            doc.text("REKAPITULASI PEMBAYARAN MEMBER (KAS)", 25, y);
            
            const myKas = storageOrganisasi.kas_tim.filter(k => k.nama === agt.nama_lengkap);
            const kasData = myKas.map((k, i) => [i+1, k.tanggal, k.jenis_pembayaran, `Rp ${parseFloat(k.nominal).toLocaleString('id-ID')}`]);

            doc.autoTable({
                startY: y + 3,
                head: [['No', 'Tanggal', 'Metode', 'Nominal']],
                body: kasData.length > 0 ? kasData : [['-', 'Belum ada data', '-', '-']],
                margin: { left: 25, right: 25 },
                theme: 'grid',
                headStyles: { fillColor: [16, 185, 129] },
                styles: { fontSize: 8 }
            });

            // Tabel 2: Rekap Kehadiran
            y = doc.lastAutoTable.finalY + 10;
            doc.setFont("helvetica", "bold");
            doc.text("REKAPITULASI KEHADIRAN (ABSENSI)", 25, y);

            const myAbs = storageOrganisasi.absensi.filter(a => a.nama === agt.nama_lengkap);
            const absData = myAbs.map((a, i) => [i+1, `${a.bulan} ${a.tahun}`, a.materi, a.kehadiran]);

            doc.autoTable({
                startY: y + 3,
                head: [['No', 'Periode', 'Materi', 'Status']],
                body: absData.length > 0 ? absData : [['-', 'Belum ada data', '-', '-']],
                margin: { left: 25, right: 25 },
                theme: 'grid',
                headStyles: { fillColor: [59, 130, 246] },
                styles: { fontSize: 8 }
            });

            doc.save(`Raport_${agt.nama_lengkap}.pdf`);
        }

