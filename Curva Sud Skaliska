<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <!-- KUNCI LAYAR AGAR TIDAK BISA DI ZOOM -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Curva Sud Skaliska Database</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Firebase SDK (Compatibility Version) -->
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-database-compat.js"></script>

    <!-- PDF Export Libraries -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.25/jspdf.plugin.autotable.min.js"></script>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Montserrat:wght@400;700&display=swap" rel="stylesheet">

    <style>
        /* Mencegah seleksi teks berlebih dan touch delay */
        body {
            touch-action: manipulation;
            -webkit-user-select: none;
            user-select: none;
            background-color: #f1f5f9;
        }
        input, textarea, select {
            -webkit-user-select: text;
            user-select: text;
        }
        .checkmark-circle {
            width: 80px; height: 80px;
            border-radius: 50%;
            border: 4px solid #10b981;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 15px;
            animation: scaleIn 0.3s ease-out forwards;
        }
        .checkmark-icon {
            font-size: 40px; color: #10b981;
            animation: drawCheck 0.2s 0.2s ease-out forwards;
            opacity: 0; transform: scale(0.5);
        }
        @keyframes scaleIn { 0% { transform: scale(0); } 100% { transform: scale(1); } }
        @keyframes drawCheck { 0% { opacity: 0; transform: scale(0.5); } 100% { opacity: 1; transform: scale(1); } }
        
        .table-container {
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 9px;
        }
        th {
            background-color: #f8fafc;
            text-align: left;
            padding: 10px 8px;
            border-bottom: 2px solid #e2e8f0;
            white-space: nowrap;
            color: #475569;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        td {
            padding: 8px;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
            color: #1e293b;
            white-space: nowrap;
        }
        .img-circle {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #e2e8f0;
            cursor: pointer;
            transition: transform 0.2s;
        }
        .img-circle:hover {
            transform: scale(1.1);
            border-color: #10b981;
        }
        .luxury-title {
            font-family: 'Playfair Display', serif;
            letter-spacing: -1px;
        }

        /* LOGIN STYLES */
        .login-bg {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .login-input {
            transition: all 0.3s;
            border: 1px solid #e2e8f0;
        }
        .login-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
            outline: none;
        }
        
        /* NOTIFICATION DOT */
        #notif-dot { display: none; }
    </style>
</head>
<body class="font-sans antialiased">

    <!-- SCREEN LOGIN -->
    <div id="login-screen" class="fixed inset-0 z-[1000] login-bg flex items-center justify-center p-4">
        <div class="w-full max-md">
            <div class="text-center mb-8">
                <h1 class="luxury-title text-4xl font-black text-white mb-2">CURVA SUD <span class="text-blue-500">SKALISKA</span></h1>
                <p class="text-slate-400 text-xs font-bold uppercase tracking-widest">Database Management System</p>
            </div>

            <!-- Login Card -->
            <div id="card-auth" class="glass-card rounded-3xl p-8">
                <div id="login-form-container">
                    <div class="flex justify-center mb-6">
                        <div class="bg-slate-100 p-1 rounded-xl flex">
                            <button onclick="switchLoginTab('admin')" id="tab-admin" class="px-6 py-2 rounded-lg text-xs font-bold transition-all bg-blue-600 text-white shadow-sm">ADMIN</button>
                            <button onclick="switchLoginTab('anggota')" id="tab-anggota" class="px-6 py-2 rounded-lg text-xs font-bold transition-all text-slate-500">ANGGOTA</button>
                        </div>
                    </div>

                    <form onsubmit="handleLogin(event)" class="space-y-4">
                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase ml-1 mb-1">Username / Nama</label>
                            <div class="relative">
                                <i class="fa-solid fa-user absolute left-4 top-3.5 text-slate-400 text-xs"></i>
                                <input type="text" id="login-user" required class="login-input w-full pl-10 pr-4 py-3 rounded-xl text-sm bg-slate-50" placeholder="Masukkan username">
                            </div>
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase ml-1 mb-1">Password / WA</label>
                            <div class="relative">
                                <i class="fa-solid fa-lock absolute left-4 top-3.5 text-slate-400 text-xs"></i>
                                <input type="password" id="login-pass" required class="login-input w-full pl-10 pr-4 py-3 rounded-xl text-sm bg-slate-50" placeholder="••••••••">
                            </div>
                        </div>
                        <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-500/30 transition-all text-xs tracking-widest uppercase">Masuk ke Sistem</button>
                    </form>
                    
                    <div class="mt-6 pt-6 border-t border-slate-100 text-center">
                        <button onclick="toggleRegister(true)" class="text-[10px] font-bold text-blue-600 uppercase tracking-wider hover:underline">Belum Terdaftar? Register Anggota</button>
                    </div>
                </div>

                <!-- Register Form (Hidden by default) -->
                <div id="register-form-container" class="hidden">
                    <div class="flex items-center mb-6">
                        <button onclick="toggleRegister(false)" class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 mr-3">
                            <i class="fa-solid fa-arrow-left text-xs"></i>
                        </button>
                        <h2 class="font-bold text-slate-800 text-sm uppercase">Registrasi Anggota</h2>
                    </div>
                    <form onsubmit="handleRegister(event)" class="space-y-3">
                        <div id="wadah-register-fields" class="space-y-3 max-h-[60vh] overflow-y-auto pr-2">
                            <!-- Fields rendered dynamically via JS (same as pendaftaran) -->
                        </div>
                        <button type="submit" class="w-full bg-emerald-600 text-white font-bold py-4 rounded-xl text-xs tracking-widest uppercase shadow-lg shadow-emerald-500/20 mt-4">Kirim Pendaftaran</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- CONTAINER UTAMA (HIDDEN UNTIL LOGIN) -->
    <div id="app-content" class="hidden max-w-md mx-auto bg-white min-h-screen shadow-xl flex flex-col justify-between relative overflow-x-hidden transition-all duration-500">
        
        <!-- HEADER HALAMAN -->
        <header class="bg-emerald-600 text-white p-4 sticky top-0 z-50 shadow-md">
            <div class="flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <button onclick="toggleSidebar(true)" class="w-10 h-10 rounded-xl bg-emerald-500/50 flex items-center justify-center hover:bg-emerald-500 transition-colors focus:outline-none">
                        <i class="fa-solid fa-bars text-lg"></i>
                    </button>
                    <div>
                        <h1 class="text-sm font-bold tracking-wide uppercase">Curva Sud Skaliska</h1>
                        <p class="text-[10px] text-emerald-100" id="label-role-user">Status: Super Admin</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <!-- ICON LAPTOP UNTUK TOGGLE VIEW -->
                    <button onclick="toggleDesktopMode()" title="Toggle Desktop View" class="w-10 h-10 rounded-full bg-blue-500/50 flex items-center justify-center hover:bg-blue-500 transition-colors">
                        <i class="fa-solid fa-laptop"></i>
                    </button>
                    <button id="btn-lonceng" onclick="tampilkanNotifikasi()" class="w-10 h-10 rounded-full bg-amber-500/50 flex items-center justify-center hover:bg-amber-500 transition-colors relative">
                        <i class="fa-solid fa-bell"></i>
                        <span id="notif-dot" class="absolute top-2 right-2 w-2 h-2 bg-rose-500 rounded-full border border-white"></span>
                    </button>
                    <button onclick="logoutSistem()" class="w-10 h-10 rounded-full bg-rose-500/50 flex items-center justify-center hover:bg-rose-500 transition-colors">
                        <i class="fa-solid fa-power-off"></i>
                    </button>
                </div>
            </div>
        </header>

        <!-- SIDEBAR DRAWER MENU -->
        <div id="sidebar-menu" class="absolute inset-y-0 left-0 w-72 bg-slate-900 text-slate-200 z-[100] shadow-2xl transform -translate-x-full transition-transform duration-300 ease-in-out flex flex-col justify-between">
            <div class="overflow-y-auto">
                <div class="p-4 bg-slate-950 border-b border-slate-800 flex justify-between items-center">
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-folder-tree text-emerald-500 text-lg"></i>
                        <span class="font-bold text-sm tracking-wide text-white uppercase">Curva Sud Skaliska</span>
                    </div>
                    <button onclick="toggleSidebar(false)" class="w-8 h-8 rounded-lg bg-slate-800 flex items-center justify-center text-slate-400 hover:text-white transition-colors">
                        <i class="fa-solid fa-xmark text-sm"></i>
                    </button>
                </div>
                <div class="p-3 space-y-1">
                    <button id="menu-dashboard" onclick="pilihMenu('page-statistik')" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-bold bg-emerald-600 text-white shadow-sm text-left transition-all">
                        <i class="fa-solid fa-chart-simple w-4 text-center"></i> Dashboard & Statistik
                    </button>
                    <button id="menu-form" onclick="pilihMenu('page-form')" class="admin-only w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-circle-plus w-4 text-center"></i> Form Input Data Terpadu
                    </button>
                    
                    <div class="admin-only pt-4 pb-2 px-4">
                        <span class="text-[10px] font-bold text-slate-500 uppercase tracking-wider">Arsip Komponen Data</span>
                    </div>

                    <button id="menu-pendaftaran" onclick="bukaHalamanArsip('pendaftaran')" class="admin-only w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-user-plus w-4 text-center text-cyan-400"></i> Data Pendaftaran
                    </button>
                    <button id="menu-anggota" onclick="bukaHalamanArsip('anggota')" class="admin-only w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-users w-4 text-center text-emerald-400"></i> Anggota Massa Tetap
                    </button>
                    <button id="menu-koordinator" onclick="bukaHalamanArsip('koordinator')" class="admin-only w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-user-tie w-4 text-center text-blue-400"></i> Data Koordinator
                    </button>
                    <button id="menu-alumni-pembina" onclick="bukaHalamanArsip('alumni_pembina')" class="admin-only w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-user-graduate w-4 text-center text-rose-400"></i> Alumni / Pembina
                    </button>
                    <button id="menu-administrasi" onclick="bukaHalamanArsip('administrasi')" class="admin-only w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-folder-open w-4 text-center text-amber-500"></i> Administrasi / Surat
                    </button>
                    <button id="menu-keuangan" onclick="bukaHalamanArsip('keuangan')" class="admin-only w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-wallet w-4 text-center text-emerald-400"></i> Data Laporan Keuangan
                    </button>
                    <button id="menu-kas-tim" onclick="bukaHalamanArsip('kas_tim')" class="admin-only w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-money-bill-trend-up w-4 text-center text-lime-400"></i> Data Pembayaran Member
                    </button>
                    <button id="menu-absensi" onclick="bukaHalamanArsip('absensi')" class="admin-only w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-clipboard-user w-4 text-center text-indigo-400"></i> Data Absensi
                    </button>
                    <button id="menu-raport" onclick="bukaHalamanArsip('raport')" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-address-card w-4 text-center text-orange-400"></i> Data Raport Anggota
                    </button>
                    <button id="menu-proker" onclick="bukaHalamanArsip('program_kerja')" class="admin-only w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-layer-group w-4 text-center text-amber-400"></i> Data Program Kerja
                    </button>
                    <button id="menu-agenda" onclick="bukaHalamanArsip('agenda')" class="admin-only w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-calendar-days w-4 text-center text-teal-400"></i> Data Agenda
                    </button>
                    <button id="menu-evaluasi" onclick="bukaHalamanArsip('evaluasi')" class="admin-only w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                        <i class="fa-solid fa-triangle-exclamation w-4 text-center text-rose-400"></i> Data Evaluasi
                    </button>
                    
                    <!-- MENU KHUSUS SUPER ADMIN -->
                    <div id="super-admin-menu">
                        <div class="pt-4 pb-2 px-4 border-t border-slate-800 mt-2">
                            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-wider">Super Admin Controls</span>
                        </div>
                        <button onclick="bukaHalamanArsip('admin')" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-xs font-semibold text-slate-400 hover:bg-slate-800 hover:text-white text-left transition-all">
                            <i class="fa-solid fa-user-gear w-4 text-center text-slate-400"></i> Data Admin Sistem
                        </button>
                    </div>
                </div>
            </div>
            <div class="p-4 bg-slate-950 text-center text-[10px] text-slate-500 border-t border-slate-800">
                Curva Sud Skaliska v3.6
            </div>
        </div>

        <!-- OVERLAY SIDEBAR -->
        <div id="sidebar-overlay" onclick="toggleSidebar(false)" class="absolute inset-0 bg-black/50 z-50 hidden transition-opacity duration-300"></div>

        <!-- KONTEN UTAMA PAGES -->
        <main class="flex-1 p-4 space-y-6">

            <!-- PAGE 1: DASHBOARD UTAMA -->
            <section id="page-statistik" class="space-y-4">
                <div id="dashboard-content" class="space-y-4 pb-8">
                    <div class="p-8 text-center text-slate-400 uppercase text-[10px] font-bold">Memuat data dashboard...</div>
                </div>
            </section>

            <!-- PAGE 2: FORM INPUT DATA -->
            <section id="page-form" class="hidden space-y-4">
                <div class="flex items-center gap-2 mb-2">
                    <button onclick="switchPage('page-statistik')" class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center text-slate-600"><i class="fa-solid fa-arrow-left text-xs"></i></button>
                    <h3 id="form-title" class="text-sm font-bold text-slate-800 uppercase">Form Input Data Terpadu</h3>
                </div>
                <div class="bg-slate-50 p-4 rounded-2xl border border-slate-200/60 space-y-4">
                    <select id="kategoriUtama" onchange="renderFormFields()" class="w-full text-xs bg-white border border-slate-200 rounded-xl px-3 py-2.5 font-semibold shadow-sm">
                        <option value="pendaftaran">Pendaftaran</option>
                        <option value="anggota">Anggota Massa Tetap</option>
                        <option value="koordinator">Koordinator</option>
                        <option value="alumni_pembina">Alumni / Pembina</option>
                        <option value="administrasi">Administrasi / Surat</option>
                        <option value="keuangan">Laporan Keuangan</option>
                        <option value="kas_tim">Pembayaran Member</option>
                        <option value="absensi">Absensi</option>
                        <option value="program_kerja">Program Kerja</option>
                        <option value="agenda">Agenda</option>
                        <option value="evaluasi">Evaluasi</option>
                        <option id="opt-admin" value="admin">Admin Sistem</option>
                    </select>
                    <form id="formDinamisSistem" onsubmit="prosesSimpanData(event)" class="space-y-3">
                        <div id="wadah-input-dinamis" class="space-y-3"></div>
                        <button type="submit" id="btnSimpanSistem" class="w-full bg-emerald-600 text-white font-bold text-xs py-3 rounded-xl shadow-md mt-4 uppercase">Simpan ke Sistem</button>
                    </form>
                </div>
            </section>

            <!-- PAGE 3: VIEW DATA ARSIP -->
            <section id="page-arsip-view" class="hidden space-y-4">
                <div class="flex flex-col gap-3">
                    <div class="flex justify-between items-center">
                        <h3 id="judul-halaman-arsip" class="text-sm font-bold text-slate-800 uppercase tracking-wider">Data Arsip</h3>
                        <div class="flex gap-1.5" id="group-ekspor">
                            <button onclick="eksporDataCSV()" class="bg-indigo-600 text-white text-[10px] font-bold px-3 py-1.5 rounded-lg">CSV</button>
                            <button onclick="eksporDataPDF()" class="bg-rose-600 text-white text-[10px] font-bold px-3 py-1.5 rounded-lg">PDF</button>
                        </div>
                    </div>
                    <div class="relative" id="group-cari">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
                            <i class="fa-solid fa-magnifying-glass text-xs"></i>
                        </span>
                        <input type="text" id="inputCariArsip" oninput="jalankanFiturCari()" placeholder="Cari data..." class="w-full text-xs pl-9 pr-4 py-2 bg-white border border-slate-200 rounded-xl shadow-sm">
                    </div>
                </div>

                <div class="table-container bg-white rounded-xl border border-slate-200 shadow-sm">
                    <div id="container-list-arsip"></div>
                </div>

                <!-- PAGINATION CONTROLS -->
                <div id="pagination-controls" class="flex justify-between items-center px-1 py-2">
                    <button onclick="ubahHalaman(-1)" id="btn-prev" class="bg-slate-100 text-slate-600 px-3 py-1.5 rounded-lg text-[10px] font-bold disabled:opacity-30">SEBELUMNYA</button>
                    <span id="info-halaman" class="text-[10px] font-bold text-slate-500 uppercase">Hal 1 dari 1</span>
                    <button onclick="ubahHalaman(1)" id="btn-next" class="bg-slate-100 text-slate-600 px-3 py-1.5 rounded-lg text-[10px] font-bold disabled:opacity-30">BERIKUTNYA</button>
                </div>

                <!-- Bagian Akumulasi Khusus Raport / Kas -->
                <div id="akumulasi-khusus-container" class="hidden mt-6 space-y-4">
                    <h4 id="judul-akumulasi" class="text-xs font-bold text-emerald-700 uppercase px-1">Data Terakumulasi</h4>
                    <div class="table-container bg-white rounded-xl border border-emerald-100 shadow-sm">
                        <div id="container-akumulasi-data"></div>
                    </div>
                </div>
            </section>
        </main>

        <footer class="p-3 bg-slate-50 text-center text-[10px] text-slate-400 border-t border-slate-100 uppercase font-bold tracking-widest">
            Curva Sud Skaliska Database - v3.6
        </footer>
    </div>

    <!-- MODAL SUCCESS -->
    <div id="modal-success" class="fixed inset-0 bg-black/60 z-[200] hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl p-6 w-full max-w-xs text-center shadow-2xl">
            <div class="checkmark-circle"><i class="fa-solid fa-check checkmark-icon"></i></div>
            <h4 class="text-base font-bold text-slate-900">Berhasil!</h4>
        </div>
    </div>

    <!-- MODAL FOTO -->
    <div id="modal-foto" class="fixed inset-0 bg-black/80 z-[300] hidden flex items-center justify-center p-4" onclick="tutupPopUpFoto()">
        <div class="relative max-w-sm w-full bg-white rounded-2xl overflow-hidden p-2 shadow-2xl" onclick="event.stopPropagation()">
            <button onclick="tutupPopUpFoto()" class="absolute top-4 right-4 w-10 h-10 bg-black/20 text-white rounded-full flex items-center justify-center backdrop-blur-md">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
            <img id="preview-foto-besar" src="" class="w-full h-auto rounded-xl object-contain max-h-[70vh]">
            <div class="p-3 text-center">
                <p id="preview-nama-foto" class="text-sm font-bold text-slate-800"></p>
                <p class="text-[10px] text-slate-500">Preview Berkas Digital</p>
            </div>
        </div>
    </div>

    <!-- MODAL NOTIFIKASI -->
    <div id="modal-notif" class="fixed inset-0 bg-black/60 z-[200] hidden flex items-center justify-center p-4" onclick="tutupNotifikasi()">
        <div class="bg-white rounded-2xl w-full max-w-sm shadow-2xl overflow-hidden" onclick="event.stopPropagation()">
            <div class="bg-amber-500 p-4 flex justify-between items-center text-white">
                <h3 class="font-bold text-sm uppercase"><i class="fa-solid fa-bell mr-2"></i> Notifikasi Kegiatan</h3>
